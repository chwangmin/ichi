# =========================================================================
#  이치(Ichi) 환경변수 예시 — 이 파일을 복사해서 `.env` 를 만드세요.
#  실제 .env 는 절대 커밋하지 마세요. (.gitignore 에 의해 제외됨)
#  발급 절차는 README.md 의 "Google Cloud 준비" 섹션을 참고하세요.
# =========================================================================

# ---- PostgreSQL ----
POSTGRES_DB=ichi
POSTGRES_USER=ichi
POSTGRES_PASSWORD=ichi_dev_pw
# SPRING_DATASOURCE_* 는 여기 두지 않는다.
#  - Docker 실행: docker-compose 가 backend 에 db:5432 자동 주입.
#  - 로컬 bootRun: application-local.yml 이 localhost:15432 사용.
#  여기 두면 로컬 실행 시 .env 의 db:5432 가 끼어들어 접속 실패.

# ---- Google OAuth 2.0 / OIDC ----
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID (웹 애플리케이션)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# 프론트가 코드를 받은 뒤 백엔드로 넘기는 흐름. 리다이렉트 URI는 프론트 주소로 등록.
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
# 프론트(브라우저)에서 Google 동의 화면으로 리다이렉트할 때 쓰는 클라이언트 ID.
# GOOGLE_CLIENT_ID 와 같은 값. Vite 는 VITE_ 접두사만 노출하므로 별도 지정.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# ---- JWT (세션 토큰 서명용) ----
# 충분히 긴 무작위 문자열. 예: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_MINUTES=10080

# ---- CORS 허용 origin (백엔드) ----
# 쉼표로 여러 개. 웹 로컬 + 모바일(Capacitor) origin 등.
# 예: http://localhost:5173,capacitor://localhost,http://localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- refresh_token 암호화 (선택) ----
# 설정하면 DB의 refresh_token을 AES-256-GCM으로 암호화 저장.
# 비워두면 개발 모드에서 평문 저장 + 경고 로그 (운영에선 반드시 설정).
# 32바이트 키를 base64로. 예: openssl rand -base64 32
TOKEN_ENC_KEY=

# ---- Google Maps JavaScript API (프론트, M6 아틀라스용) ----
# Vite는 VITE_ 접두사 변수만 클라이언트에 노출.
VITE_GOOGLE_MAPS_API_KEY=your-maps-js-api-key

# ---- VWorld Geocoder API (백엔드, 날씨 위치 주소 검색용) ----
# 브라우저에 노출하지 않는다. VWorld 콘솔에서 발급받은 인증키.
VWORLD_API_KEY=your-vworld-api-key

# ---- 프론트가 호출할 백엔드 베이스 경로 (보통 그대로 둠) ----
VITE_API_BASE=/api

# ---- Google Analytics (gtag.js, 프론트) ----
# Google Analytics 4 측정 ID. 비워두면 추적 스크립트를 로드하지 않음.
# (로컬/개발에선 비워두는 것을 권장)
VITE_GA_MEASUREMENT_ID=
