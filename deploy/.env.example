# =========================================================================
#  이치(Ichi) 배포용 환경변수 예시 — 복사해서 deploy/.env 를 만드세요.
#    cd deploy && cp .env.example .env   →   운영 값으로 채우기
#
#  ⚠️ 루트 .env(개발용, localhost)와 다릅니다. 아래 값은 실제 도메인/운영 시크릿으로.
#  ⚠️ deploy/.env 는 절대 커밋 금지 (.gitignore 가 모든 .env 를 제외).
#  실행:  docker compose -f docker-compose.app.yml up -d --build db frontend api-edge backend-blue
#  진입:  외부 Nginx Proxy Manager(NPM)가 도메인/TLS 처리 →
#         도메인 /     → ichi-frontend:80,   도메인 /api/ → ichi-api-edge:80
#         (frontend/api-edge 는 NPM 과 같은 npm-network 에 join, 포트 외부 노출 없음)
# =========================================================================

# ---- PostgreSQL ----
POSTGRES_DB=ichi
POSTGRES_USER=ichi
# 운영용 강한 비밀번호로 교체 (필수)
POSTGRES_PASSWORD=change-me-strong-db-password

# ---- 백엔드 DB 접속 (보통 그대로 — compose 네트워크의 db 서비스) ----
# 비우면 db:5432/ichi, POSTGRES_PASSWORD 를 사용.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/ichi
SPRING_DATASOURCE_USERNAME=ichi
# 비우면 POSTGRES_PASSWORD 를 그대로 사용. 다르게 쓰려면 여기 지정.
SPRING_DATASOURCE_PASSWORD=

# ---- Google OAuth 2.0 / OIDC ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# 운영 도메인 기준 (Google Cloud Console 의 승인된 리디렉션 URI 에도 등록!)
GOOGLE_REDIRECT_URI=https://your-domain.example/auth/callback
# 프론트(브라우저)용 — 빌드 시점에 번들로 박힘. 값 바꾸면 frontend 재빌드 필요.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=https://your-domain.example/auth/callback

# ---- JWT (세션 토큰 서명) ----
# 운영용 새 랜덤값(>=32바이트). 예: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_MINUTES=10080

# ---- refresh_token 암호화 (운영 필수) ----
# 운영에선 반드시 설정. 예: openssl rand -base64 32
TOKEN_ENC_KEY=change-me-base64-32byte-key

# ---- CORS 허용 origin (백엔드) ----
# 운영 도메인. 모바일(Capacitor) origin 추가 가능. 쉼표 구분.
CORS_ALLOWED_ORIGINS=https://your-domain.example

# ---- 쿠키 보안 (HTTPS 운영이면 true) ----
ICHI_COOKIE_SECURE=true

# ---- Google Maps JavaScript API (프론트) ----
# 빌드 시점에 번들로 박힘. 값 바꾸면 frontend 재빌드 필요.
VITE_GOOGLE_MAPS_API_KEY=your-maps-js-api-key

# ---- VWorld Geocoder API (백엔드) ----
# 날씨 위치 주소 검색용. 브라우저에 노출하지 않는다.
VWORLD_API_KEY=your-vworld-api-key

# ---- 프론트가 호출할 백엔드 베이스 경로 (보통 그대로) ----
VITE_API_BASE=/api

# ---- 배포 옵션 ----
# 진입점은 외부 NPM(Nginx Proxy Manager). 이 compose 는 포트를 외부로 노출하지 않고
# frontend/api-edge 를 npm-network 로 NPM 과 연결한다. (EDGE_PORT 더 이상 사용 안 함)
#
# NPM 이 쓰는 외부 도커 네트워크 이름. NPM 컨테이너가 먼저 만들어 둔 네트워크여야 한다.
# 확인:  docker network ls | grep npm
NPM_NETWORK=npm-network
# 이미지 태그 (CI 에서 커밋 SHA 등으로 주입 가능)
IMAGE_TAG=latest

# ---- Google Analytics (gtag.js, 프론트) ----
# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX).
# 빌드 시점에 번들로 박힘. 값 바꾸면 frontend 재빌드 필요.
# 비워두면 추적 스크립트를 로드하지 않음 → 운영에선 채워야 추적됨.
VITE_GA_MEASUREMENT_ID=
